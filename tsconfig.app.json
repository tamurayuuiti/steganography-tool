{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",

    "target": "ES2023",
    "lib": ["ES2023", "DOM"],

    "module": "ESNext",
    "moduleResolution": "bundler",

    "types": ["vite/client"],

    "jsx": "react-jsx",

    "verbatimModuleSyntax": true,
    "moduleDetection": "force",

    "noEmit": true,
    "skipLibCheck": true,

    "strict": true,

    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    "paths": {
      "@/*": ["./src/*"]
    }
  },

  "include": ["src"]
}